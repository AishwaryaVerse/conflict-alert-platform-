{
  "name": "conflict-detection-platform",
  "version": "1.0.0",
  "description": "Full-stack Conflict Detection Platform",
  "scripts": {
    "start": "nodemon server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd . && npm start",
    "client": "cd client && npm start",
    "install-server": "npm install",
    "install-client": "cd client && npm install"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "body-parser": "^1.20.2",
    "nodemon": "^3.0.1"
  }
}